# Frontend (Vite) — browser-exposed. Use anon or publishable key only.
# Never add service_role, sb_secret_*, or SUPABASE_JWT_SECRET here.
#
# Get values from: Supabase Dashboard → Project Settings → API
# Copy this file to .env in the same folder (strategiq-app root).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Set to "true" on the landing-page production branch (only the waitlist is public).
VITE_LANDING_ONLY=false

# Optional: Tally form URL (opens in new tab instead of Supabase waitlist table).
VITE_TALLY_FORM_URL=

# Optional: external link for "Free Brand Pulse Check" nav/footer link.
VITE_PULSE_CHECK_URL=
