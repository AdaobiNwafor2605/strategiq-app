# Backend only — copy to backend/.env (gitignored). Do not reuse in frontend .env.
#
# Get values from: Supabase Dashboard → Project Settings → API
# All config for strategiq-app lives in this repo — no other project folder needed.
#
# SUPABASE_JWT_SECRET: JWT Secret (or legacy JWT secret)
SUPABASE_JWT_SECRET=
# SUPABASE_URL: Project URL (same host as VITE_SUPABASE_URL in root .env)
SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY: service_role key — server-side only, never in the frontend
SUPABASE_SERVICE_ROLE_KEY=
