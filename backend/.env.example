# Backend only — copy to backend/.env (gitignored). Do not reuse in frontend .env.
# SUPABASE_JWT_SECRET: Supabase Dashboard → Project Settings → API → JWT Secret
SUPABASE_JWT_SECRET=
# SUPABASE_URL: Supabase Dashboard → Project Settings → API → Project URL
SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY: Supabase Dashboard → Project Settings → API → service_role key
# Required for server-side account deletion. Never expose this in the frontend.
SUPABASE_SERVICE_ROLE_KEY=
